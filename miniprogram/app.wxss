page {
  background: #f6f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 32rpx;
  box-sizing: border-box;
}

.panel {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 32rpx 0 16rpx;
}

.muted {
  color: #6b7280;
}

.button {
  background: #2563eb;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  text-align: center;
  margin-bottom: 18rpx;
}

.button.secondary {
  background: #475569;
}

.button.warning {
  background: #b45309;
}

.button.ghost {
  background: #e5e7eb;
  color: #111827;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  padding: 12rpx 0;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.metric {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.metric-label {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  color: #374151;
  font-size: 22rpx;
}

.tag.ok {
  background: #dcfce7;
  color: #166534;
}

.tag.warn {
  background: #fef3c7;
  color: #92400e;
}

.tag.bad {
  background: #fee2e2;
  color: #991b1b;
}

.input {
  background: #f8fafc;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  padding: 18rpx;
  margin: 12rpx 0 20rpx;
  min-height: 44rpx;
}

.list-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.item-title {
  font-weight: 600;
  margin-bottom: 10rpx;
}

.item-meta {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}
