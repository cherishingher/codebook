page {
  background: #f6f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 32rpx;
}

.panel {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.muted {
  color: #6b7280;
}

.button {
  background: #2563eb;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  text-align: center;
}

