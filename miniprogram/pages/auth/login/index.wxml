<view class="page">
  <view class="panel">
    <view class="title">Codebook</view>
    <view class="muted">本地化智能课时考勤系统</view>
  </view>
  <view class="panel">
    <view class="item-title">后端 API 地址</view>
    <input class="input" value="{{apiBaseUrl}}" bindinput="onApiInput" />
    <view class="muted">开发工具本机演示默认使用 http://127.0.0.1:8000/api/v1，真实手机预览请改成 Mac 局域网 IP 或 HTTPS 域名。</view>
  </view>
  <view class="panel">
    <view class="item-title">真实部署调试身份</view>
    <view class="muted">微信登录绑定完成前，可以先用后台返回的 ID 进入各端。</view>
    <input class="input" type="number" placeholder="校区ID campusId" value="{{campusId}}" bindinput="onCampusInput" />
    <input class="input" type="number" placeholder="学员ID studentId" value="{{studentId}}" bindinput="onStudentInput" />
    <input class="input" type="number" placeholder="老师ID teacherId" value="{{teacherId}}" bindinput="onTeacherInput" />
    <view class="button" bindtap="enterLearner">进入学员/家长端</view>
    <view class="button secondary" bindtap="enterTeacher">进入教师端</view>
    <view class="button warning" bindtap="enterCampus">进入校区端</view>
  </view>
  <view class="button" bindtap="connectDemo">连接并生成演示数据</view>
  <view class="button secondary" bindtap="goRoleSwitch">直接进入身份选择</view>
</view>
