<view class="page">
  <view class="panel">
    <view class="title">{{studentName || '学员端'}}</view>
    <view class="muted">{{campusName}} · {{courseName}}</view>
  </view>
  <view class="metric-grid">
    <view class="metric">
      <view class="metric-label">剩余课时</view>
      <view class="metric-value">{{balanceText}}</view>
    </view>
    <view class="metric">
      <view class="metric-label">最近考勤</view>
      <view class="metric-value">{{latestAttendance}}</view>
    </view>
  </view>
  <view class="section-title">最近课次</view>
  <view wx:for="{{lessons}}" wx:key="id" class="list-item">
    <view class="item-title">课次 #{{item.lesson_id}}</view>
    <view class="item-meta">考勤：{{item.attendanceText}} · 消课：{{item.deductionText}}</view>
    <view class="item-meta">已消课时：{{item.deducted_hours}}</view>
  </view>
  <view class="button" bindtap="goSchedule">查看课表</view>
  <view class="button secondary" bindtap="goHours">查看课时流水</view>
  <view class="button ghost" bindtap="switchRole">切换身份</view>
</view>
