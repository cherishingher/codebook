<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codebook.api</string>
  <key>WorkingDirectory</key>
  <string>/opt/codebook/backend</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/codebook/backend/.venv/bin/uvicorn</string>
    <string>app.main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8000</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Volumes/AttendanceData/storage/logs/api.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Volumes/AttendanceData/storage/logs/api.err.log</string>
</dict>
</plist>

