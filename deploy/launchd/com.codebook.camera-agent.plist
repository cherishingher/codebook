<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codebook.camera-agent</string>
  <key>WorkingDirectory</key>
  <string>/opt/codebook/camera-agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/codebook/camera-agent/.venv/bin/python</string>
    <string>-m</string>
    <string>agent.main</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Volumes/AttendanceData/storage/logs/camera-agent.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Volumes/AttendanceData/storage/logs/camera-agent.err.log</string>
</dict>
</plist>

